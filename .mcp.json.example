{
  "mcpServers": {
    "kingdee": {
      "command": "uvx",
      "args": ["kingdee-mcp"],
      "env": {
        "KINGDEE_SERVER_URL": "http://your-server/k3cloud/",
        "KINGDEE_ACCT_ID": "your-acct-id",
        "KINGDEE_USERNAME": "your-username",
        "KINGDEE_APP_ID": "your-app-id",
        "KINGDEE_APP_SEC": "your-app-secret",
        "KINGDEE_LCID": "2052"
      }
    }
  }
}
