# 金蝶云星空私有云连接配置
# 复制本文件为 .env 并填入真实值

# 私有云地址（末尾加 /k3cloud/）
KINGDEE_SERVER_URL=http://192.168.1.100:8080/k3cloud/

# 账套ID（金蝶管理中心 → 数据中心标识）
KINGDEE_ACCT_ID=your_acct_id

# 集成用户名（系统管理 → 第三方系统登录授权 → 集成用户，不要用 Administrator）
KINGDEE_USERNAME=API集成

# 应用ID（第三方系统登录授权生成）
KINGDEE_APP_ID=your_app_id

# 应用密钥（第三方系统登录授权生成）
KINGDEE_APP_SEC=your_app_secret
